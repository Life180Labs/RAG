# Copy to .env and adjust as needed for local development.
# Individual services also read backend/.env, frontend/.env.local, worker/.env
# when run outside Docker Compose; Compose injects these values directly.

POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=ragadminsecret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=rag-documents

BACKEND_PORT=8000
FRONTEND_PORT=3000

JWT_SECRET_KEY=change-me-in-production
