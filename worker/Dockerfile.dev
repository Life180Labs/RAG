FROM python:3.11-slim
WORKDIR /app
ENV PYTHONPATH=/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc tesseract-ocr poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY . .
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir -e ".[dev]"
RUN python -c "import tiktoken; tiktoken.get_encoding('cl100k_base')"
# Only the default local embedding model (bge, ~130MB) is pre-cached at
# build time to keep the image/build reasonable; e5/nomic are real,
# available providers too but download on first use instead (documented
# trade-off, not a functional gap).
RUN python -c "from common.embedding_providers.local import LOCAL_MODEL_NAMES, _load_model; _load_model(LOCAL_MODEL_NAMES['bge'])"
# Same tradeoff for reranking (Phase 13): only the lightweight default
# cross-encoder (~80MB) is pre-cached; the larger BGE reranker (~1GB)
# and FlashRank's tiny model (~3MB, cheap enough not to bother) download
# on first use instead.
RUN python -c "from retrieval_worker.reranking.local import LOCAL_MODEL_NAMES, _load_model; _load_model(LOCAL_MODEL_NAMES['cross_encoder'])"

CMD ["celery", "-A", "common.celery_app", "worker", "--loglevel=info", "--concurrency=2"]
